{"manifest_version":3,"name":"QuietText 2.0","version":"2.0","description":"AI reading assistant powered by Gemma 4 and Groq. Simplifies text, PDFs and images for people with dyslexia.","permissions":["storage","contextMenus","activeTab","scripting","tabs"],"host_permissions":["https://api.groq.com/*","https://quiettext.vercel.app/*"],"background":{"service_worker":"background.js"},"content_scripts":[{"matches":["<all_urls>"],"js":["content.js"],"css":["content.css"]}],"action":{"default_popup":"popup.html","default_icon":{"16":"icons/icon16.png","48":"icons/icon48.png","128":"icons/icon128.png"}},"commands":{"open-panel":{"suggested_key":{"default":"Ctrl+Shift+Q","mac":"Command+Shift+Q"},"description":"Open QuietText 2.0 with selected text"}},"web_accessible_resources":[{"resources":["panel.html","fonts/*"],"matches":["<all_urls>"]}]}